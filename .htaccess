RewriteEngine On
RewriteBase /apod/

# Keep application internals and utility scripts out of direct web access.
RewriteRule ^(app|scripts)/ - [F,L]
RewriteRule ^audit\.php$ - [F,L]
RewriteRule ^(README|AGENTS)\.md$ - [F,L]
RewriteRule ^data/(apod\.json|stopwords\.txt)$ - [F,L]

# -----------------------------------------
# DO NOT REWRITE requests for static assets
# -----------------------------------------

# Let Apache handle these normally
RewriteCond %{REQUEST_URI} ^/apod/images/ [OR]
RewriteCond %{REQUEST_URI} ^/apod/thumbs/ [OR]
RewriteCond %{REQUEST_URI} ^/apod/assets/
RewriteRule ^ - [L]

# Let Apache handle real files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# -----------------------------------------
# PRETTY ROUTES
# -----------------------------------------

# Route: /image/<slug>
RewriteRule ^image/([a-z0-9-]+)/?$ index.php?page=image&slug=$1 [L,QSA]

# Optional: fallback route for bare slugs (commented out)
# RewriteRule ^([a-z0-9-]+)/?$ index.php?page=image&slug=$1 [L,QSA]

RewriteRule ^(gallery|about|random)/?$ index.php?page=$1 [L,QSA]

# Everything else → index.php (for routing or 404)
RewriteRule ^.*$ index.php [L,QSA]

# -----------------------------------------
# SECURITY / OPTIMIZATION
# -----------------------------------------

# Block hidden files like .git, .env
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Prevent directory browsing
Options -Indexes

# Deny access to sensitive file types
<FilesMatch "\.(bak|config|sql|ini|log|sh|inc|swp|dist)$">
  Require all denied
</FilesMatch>

# Disable ETags to clean up caching
Header unset ETag
FileETag None

# Set UTF-8 charset for all responses
AddDefaultCharset utf-8

# Enable GZIP compression for performance
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml image/svg+xml
</IfModule>

<IfModule mod_headers.c>
  Header append Vary Accept-Encoding
</IfModule>


# Set long cache expiry headers for static files
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Basic bot blocking
RewriteCond %{HTTP_USER_AGENT} libwww-perl|python-requests|wget|curl [NC]
RewriteRule .* - [F,L]

# Reject suspicious query strings
RewriteCond %{REQUEST_URI} ^.{2000,} [OR]
RewriteCond %{QUERY_STRING} (\.\.\/|etc/passwd|input_file|mosConfig_) [NC]
RewriteRule ^.*$ - [F,L]
